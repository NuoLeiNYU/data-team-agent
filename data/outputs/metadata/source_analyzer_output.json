{
  "work_plan_context": {
    "project_name": "Retail Sales Analytics DW - Phase 1",
    "business_purpose": "Build a dimensional warehouse for sales performance, customer behavior, and product profitability analysis.",
    "target_metrics": [
      {
        "name": "Total Sales Revenue",
        "definition": "SUM(total_amount) by time period",
        "target": "Accurate and reconcilable with source transactions"
      },
      {
        "name": "Average Transaction Value",
        "definition": "SUM(total_amount) / COUNT(transaction_id)",
        "target": "Available by calendar and region"
      },
      {
        "name": "Customer Lifetime Value by Loyalty Tier",
        "definition": "SUM(total_amount) by customer and loyalty_tier",
        "target": "Supported via fact_sales and dim_customer"
      },
      {
        "name": "Product Profitability",
        "definition": "(unit_price - unit_cost) * quantity by category",
        "target": "Derived with product cost and sales quantity"
      }
    ],
    "source_systems": [
      {
        "source_name": "Local Retail CSV Sources",
        "source_type": "file",
        "location_or_connection": "data/sources/*.csv",
        "data_owner": "Retail Analytics Team",
        "refresh_cadence": "Batch (as delivered)",
        "notes": "Phase 1 sample files"
      }
    ],
    "business_process": "Retail sales transactions",
    "expected_fact_grain": "One row per transaction (transaction_id level)",
