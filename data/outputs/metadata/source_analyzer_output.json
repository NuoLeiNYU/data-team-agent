      "dim_product",
      "dim_calendar",
      "dim_store",
      "dim_payment_method"
    ],
    "constraints_compliance": "Naming standards fact_*/dim_*, PII handling for name/email, zero nulls in PK/FK fields, and full source-to-target mapping coverage."
